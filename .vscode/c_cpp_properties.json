{
    "configurations": [
        {
            "name": "Raspberry Pi",
            "includePath": [
                "${workspaceFolder}/**",
                "/usr/include",
                "/usr/local/include",

                
                "/usr/include/aarch64-linux-gnu/qt6",
                "/usr/include/aarch64-linux-gnu/qt6/QtCore",
                "/usr/include/aarch64-linux-gnu/qt6/QtGui",
                "/usr/include/aarch64-linux-gnu/qt6/QtQuick",
                "/usr/include/aarch64-linux-gnu/qt6/QtQml"
            ],
            "defines": [
                "QT_CORE_LIB",
                "QT_GUI_LIB",
                "QT_QML_LIB",
                "QT_QUICK_LIB"
            ],
            "compilerPath": "/usr/bin/g++",
            "cStandard": "c17",
            "cppStandard": "c++20",
            "intelliSenseMode": "linux-gcc-arm64"
        }
    ],
    "version": 4
}